# Analysis result for a single chemical element

# Element symbol (e.g., "Fe", "Si")
string element_symbol

# Full element name (e.g., "Iron", "Silicon")
string element_name

# Confidence score of the detection (0.0 to 1.0)
float64 confidence

# Relative intensity of the characteristic peak found
float64 relative_intensity

# The specific wavelength where the peak was detected
float64 wavelength_detected
